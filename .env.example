# Fastmail Integration (via exe.dev)
# Set FASTMAIL_ENDPOINT to your integration URL
FASTMAIL_ENDPOINT=https://fastmail.int.exe.xyz/jmap/api/
FASTMAIL_ACCOUNT_ID=your_fastmail_account_id_here
FASTMAIL_MAILBOX_ID=Drafts

# Optional: Direct token auth (alternative to integration)
# Only needed if NOT using exe.dev integration
# Get token from: https://www.fastmail.com/settings/security/tokens
# FASTMAIL_ACCESS_TOKEN=your_token_here
