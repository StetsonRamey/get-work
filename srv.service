[Unit]
Description=Resume PDF server

[Service]
Type=simple
User=exedev
Group=exedev
WorkingDirectory=/home/exedev/get-work
ExecStart=/usr/bin/python3 /home/exedev/get-work/serve.py
Restart=always
RestartSec=5
Environment=HOME=/home/exedev
Environment=USER=exedev
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
