#!/usr/bin/env python3
"""Small CLI wrapper for the get-work outreach toolkit."""
from __future__ import annotations

import argparse
import os
import signal
import subprocess
import sys
import time
from pathlib import Path

ROOT = Path(__file__).resolve().parent
SCRIPTS = ROOT / "scripts"
RUNTIME_DIR = ROOT / ".runtime"
PREVIEW_PID = RUNTIME_DIR / "preview.pid"
LIVE_PREVIEW_PID = RUNTIME_DIR / "live-preview.pid"


def run(cmd: list[str]) -> int:
    """Run a project command from the repo root."""
    return subprocess.run(cmd, cwd=ROOT).returncode


def script(name: str) -> str:
    return str(SCRIPTS / name)


class ExamplesFormatter(argparse.RawDescriptionHelpFormatter, argparse.ArgumentDefaultsHelpFormatter):
    pass


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="getwork",
        description="CLI for Stetson's get-work outreach toolkit.",
        formatter_class=ExamplesFormatter,
        epilog="""Examples:
  getwork email holiglows --variant 1 --dry-run
  getwork email holiglows --variant 2
  getwork new-holiday-prospect holiglows "HoliGlows" "https://www.holiglows.com/"
  getwork scrape https://www.holiglows.com/
  getwork build-prospect tulsalights "Tulsa Lights" https://tulsalights.com/ --location "Tulsa, OK"
  getwork summary
  getwork live-preview --port 8765
  getwork live-preview start --port 8765
  getwork live-preview stop
  getwork build outreach/prospects/holiglows/portfolio.html

Aliases:
  get-work works too if installed via `getwork install`.
""",
    )
    sub = parser.add_subparsers(dest="command", metavar="command", required=True)

    email = sub.add_parser("email", help="preview/create a Fastmail draft for a prospect")
    email.add_argument("prospect", help="prospect slug, e.g. holiglows")
    email.add_argument("index", nargs="?", help="optional legacy zero-based variant index: 0 or 1")
    email.add_argument("--variant", type=int, choices=(1, 2), help="email variant to draft")
    email.add_argument("--dry-run", action="store_true", help="preview without creating a draft")
    email.add_argument("--all", action="store_true", help="preview/create all variants")

    np = sub.add_parser("new-prospect", help="scaffold a standard prospect")
    np.add_argument("slug", help="prospect slug")
    np.add_argument("display_name", nargs="?", help="display/company name")

    nhp = sub.add_parser("new-holiday-prospect", help="scaffold a holiday-lighting prospect")
    nhp.add_argument("slug", help="prospect slug")
    nhp.add_argument("display_name", nargs="?", help="display/company name")
    nhp.add_argument("website", nargs="?", help="prospect website URL")

    scrape = sub.add_parser("scrape", help="scrape a company website for contact info")
    scrape.add_argument("url", help="company website URL")
    scrape.add_argument("--json", action="store_true", help="emit JSON")

    bp = sub.add_parser("build-prospect", help="scrape + scaffold + fill notes + update summary")
    bp.add_argument("slug", help="prospect slug")
    bp.add_argument("display_name", help="display/company name")
    bp.add_argument("website", help="company website URL")
    bp.add_argument("--location", default="", help="location / service area")
    bp.add_argument("--force", action="store_true", help="rebuild over existing folder")
    bp.add_argument("--no-scrape", action="store_true", help="skip web scraping")

    sub.add_parser("summary", help="regenerate outreach/summary.html tracking table")

    preview = sub.add_parser("preview", help="manage no-cache preview server")
    preview.add_argument("preview_action", nargs="?", choices=("start", "stop", "status", "restart"), default="start")
    preview.add_argument("--port", "-p", default="8765", help="port to serve on")
    preview.add_argument("--foreground", "-f", action="store_true", help="run in foreground instead of background")

    live = sub.add_parser("live-preview", help="manage BrowserSync live preview server")
    live.add_argument("preview_action", nargs="?", choices=("start", "stop", "status", "restart"), default="start")
    live.add_argument("--port", "-p", default="8765", help="port to serve on")
    live.add_argument("--foreground", "-f", action="store_true", help="run in foreground instead of background")

    sub.add_parser("stop-preview", help="stop preview and live-preview background servers")

    build = sub.add_parser("build", help="build PDF from portfolio HTML")
    build.add_argument("html", nargs="?", help="HTML file to build; defaults to base portfolio")

    add_domain = sub.add_parser("add-domain", help="add Cloudflare CNAME for a prospect slug")
    add_domain.add_argument("slug", help="prospect slug")

    sub.add_parser("index", help="regenerate outreach/index.html")
    sub.add_parser("serve", help="run production-style slug/PDF server on port 8000")

    install = sub.add_parser("install", help="install getwork and get-work shims into ~/.local/bin")
    install.add_argument("--dir", default=str(Path.home() / ".local" / "bin"), help="install directory")

    return parser



def external_base(port: str) -> str:
    return "https://get-work.exe.xyz" if str(port) == "8000" else f"https://get-work.exe.xyz:{port}"


def pid_running(pid: int) -> bool:
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    return True


def read_pid(pid_file: Path) -> int | None:
    try:
        return int(pid_file.read_text().strip())
    except (FileNotFoundError, ValueError):
        return None


def stop_managed(name: str, pid_file: Path) -> int:
    pid = read_pid(pid_file)
    if not pid:
        print(f"{name} is not running (no pidfile).")
        return 0
    if not pid_running(pid):
        pid_file.unlink(missing_ok=True)
        print(f"{name} is not running (stale pidfile removed).")
        return 0

    print(f"→ Stopping {name} (process group {pid})")
    try:
        os.killpg(pid, signal.SIGTERM)
    except ProcessLookupError:
        pid_file.unlink(missing_ok=True)
        print(f"✓ {name} already stopped")
        return 0

    for _ in range(30):
        if not pid_running(pid):
            pid_file.unlink(missing_ok=True)
            print(f"✓ Stopped {name}")
            return 0
        time.sleep(0.1)

    print(f"→ {name} did not stop after SIGTERM; sending SIGKILL")
    try:
        os.killpg(pid, signal.SIGKILL)
    except ProcessLookupError:
        pass
    pid_file.unlink(missing_ok=True)
    print(f"✓ Stopped {name}")
    return 0


def status_managed(name: str, pid_file: Path) -> int:
    pid = read_pid(pid_file)
    if pid and pid_running(pid):
        print(f"✓ {name} is running (pid/process group {pid})")
        return 0
    if pid:
        pid_file.unlink(missing_ok=True)
        print(f"✗ {name} is not running (removed stale pidfile)")
    else:
        print(f"✗ {name} is not running")
    return 1


def start_managed(name: str, pid_file: Path, cmd: list[str], port: str, foreground: bool = False) -> int:
    if foreground:
        return run(cmd)

    existing = read_pid(pid_file)
    if existing and pid_running(existing):
        print(f"✓ {name} is already running (pid/process group {existing})")
        print(f"  Open: {external_base(port)}/")
        print(f"  Stop: getwork {'live-preview' if name == 'live-preview' else 'preview'} stop")
        return 0
    pid_file.unlink(missing_ok=True)

    RUNTIME_DIR.mkdir(exist_ok=True)
    log_file = RUNTIME_DIR / f"{name}.log"
    log = log_file.open("ab")
    proc = subprocess.Popen(
        cmd,
        cwd=ROOT,
        stdout=log,
        stderr=subprocess.STDOUT,
        start_new_session=True,
    )
    pid_file.write_text(str(proc.pid))
    time.sleep(0.4)
    if proc.poll() is not None:
        pid_file.unlink(missing_ok=True)
        print(f"✗ {name} failed to start. Log:")
        try:
            print(log_file.read_text(errors="replace")[-4000:])
        except FileNotFoundError:
            pass
        return proc.returncode or 1

    print(f"✓ Started {name} in the background (pid/process group {proc.pid})")
    print(f"  Open:   {external_base(port)}/")
    print(f"  Log:    {log_file}")
    print(f"  Status: getwork {name} status")
    print(f"  Stop:   getwork {name} stop")
    return 0


def manage_preview(name: str, action: str, port: str, foreground: bool, cmd: list[str], pid_file: Path) -> int:
    if action == "start":
        return start_managed(name, pid_file, cmd, port, foreground)
    if action == "stop":
        return stop_managed(name, pid_file)
    if action == "status":
        return status_managed(name, pid_file)
    if action == "restart":
        stop_managed(name, pid_file)
        return start_managed(name, pid_file, cmd, port, foreground)
    raise AssertionError(action)

def install_shims(directory: str) -> int:
    install_dir = Path(directory).expanduser()
    install_dir.mkdir(parents=True, exist_ok=True)
    target = ROOT / "getwork"
    for name in ("getwork", "get-work"):
        link = install_dir / name
        if link.exists() or link.is_symlink():
            link.unlink()
        link.symlink_to(target)
        print(f"✓ Installed {link} -> {target}")
    print("")
    print(f"Make sure {install_dir} is in your PATH.")
    return 0


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)

    match args.command:
        case "email":
            cmd = [script("create-email-draft.py"), args.prospect]
            if args.index is not None:
                cmd.append(args.index)
            if args.variant:
                cmd.extend(["--variant", str(args.variant)])
            if args.all:
                cmd.append("--all")
            if args.dry_run:
                cmd.append("--dry-run")
            return run(cmd)
        case "new-prospect":
            cmd = [script("new-prospect.sh"), args.slug]
            if args.display_name:
                cmd.append(args.display_name)
            return run(cmd)
        case "new-holiday-prospect":
            cmd = [script("new-holiday-prospect.sh"), args.slug]
            if args.display_name:
                cmd.append(args.display_name)
            if args.website:
                cmd.append(args.website)
            return run(cmd)
        case "scrape":
            cmd = [script("scrape-prospect.py"), args.url]
            if args.json:
                cmd.append("--json")
            return run(cmd)
        case "build-prospect":
            cmd = [script("build-prospect.py"), args.slug, args.display_name, args.website]
            if args.location:
                cmd.extend(["--location", args.location])
            if args.force:
                cmd.append("--force")
            if args.no_scrape:
                cmd.append("--no-scrape")
            return run(cmd)
        case "summary":
            return run([script("generate-summary.py")])
        case "preview":
            return manage_preview(
                "preview",
                args.preview_action,
                str(args.port),
                args.foreground,
                [script("preview.sh"), str(args.port)],
                PREVIEW_PID,
            )
        case "live-preview":
            return manage_preview(
                "live-preview",
                args.preview_action,
                str(args.port),
                args.foreground,
                [script("live-preview.sh"), str(args.port)],
                LIVE_PREVIEW_PID,
            )
        case "stop-preview":
            code1 = stop_managed("live-preview", LIVE_PREVIEW_PID)
            code2 = stop_managed("preview", PREVIEW_PID)
            return code1 or code2
        case "build":
            cmd = [script("build.sh")]
            if args.html:
                cmd.append(args.html)
            return run(cmd)
        case "add-domain":
            return run([script("add-domain.sh"), args.slug])
        case "index":
            return run([script("generate-outreach-index.py")])
        case "serve":
            return run([sys.executable, str(ROOT / "serve.py")])
        case "install":
            return install_shims(args.dir)
        case _:
            raise AssertionError(f"Unhandled command: {args.command}")


if __name__ == "__main__":
    raise SystemExit(main())
